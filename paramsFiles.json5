[
  {
    "passage": "Bus seat",
    "findString": "<<if dangerEvent()>>",
    "replace": "<<if dangerEvent() and !$options.noBusHarassmentNormal>>",
    "debug": true
  },
  {
    "passage": "Bus Pregnancy Touch",
    "findString": "<<if dangerEvent() and $rng gte 91>>",
    "replace": "<<if dangerEvent() and $rng gte 91 and !$options.noBusHarassmentPregnancy>>",
    "debug": true
  },
  {
    "passage": "Passout bus",
    "findString": "<<if dangerEvent()>>",
    "replace": "<<if dangerEvent() and !$options.noBusHarassmentPassout>>",
    "debug": true
  }
]
